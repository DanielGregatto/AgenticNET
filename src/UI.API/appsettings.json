{
  "Application": {
    "Name": "AgenticNET"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=your-server.database.windows.net;Database=YourDatabase;Authentication=Active Directory Default;Encrypt=True;MultipleActiveResultSets=True;"
  },
  "DefaultSchema": "AgenticNET",
  "Schema": "ANET_",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ApplicationInsights": {
    "InstrumentationKey": "",
    "ConnectionString": ""
  },
  "EmailConfig": {
    "Host": "smtp.example.com",
    "SmtpPort": 587,
    "Email": "noreply@example.com",
    "Password": "your-email-password",
    "Name": "CQRS API",
    "UseSSL": true,
    "MainUrl": "https://your-frontend-url.com/",
    "MainUrlHelp": "https://your-frontend-url.com/contact",
    "MainUrlPayment": "https://your-frontend-url.com/account"
  },
  "Jwt": {
    "Issuer": "CQRS-API",
    "Secret": "your-secret-key-min-32-characters-long-change-this",
    "MinutesValid": "60",
    "Audience": "https://your-frontend-url.com/",
    "RedirectUriExternalLogin": "https://your-frontend-url.com/auth/external-login",
    "RedirectUriEmailConfirm": "https://your-frontend-url.com/auth/email-confirmed",
    "RedirectUriResetPassword": "https://your-frontend-url.com/auth/reset-password"
  },
  "ReCaptcha": {
    "SiteKey": "your-recaptcha-site-key",
    "Secret": "your-recaptcha-secret"
  },
  "Authentication": {
    "Facebook": {
      "AppId": "your-facebook-app-id",
      "AppSecret": "your-facebook-app-secret"
    },
    "Google": {
      "ClientId": "your-google-client-id.apps.googleusercontent.com",
      "ClientSecret": "your-google-client-secret"
    }
  },
  "AllowedHosts": "*",
  "SecretEndpointConfig": {
    "APIKey": "your-api-key-guid"
  },
  "AzureStorage": {
    "AccountName": "your-storage-account-name",
    "Container": "keys",
    "BlobName": "dataprotectionkeys.xml"
  },
  "Turnstile": {
    "SecretKey": "your-turnstile-secret-key"
  },
  "RateLimit": {
    "BypassToken": "your-bypass-token-for-testing",
    "BypassHeaderName": "x-test-bypass",
    "DefaultTokenLimit": 20,
    "DefaultTokensPerPeriod": 20,
    "DefaultReplenishmentPeriodSeconds": 20,
    "BypassTokenLimit": 1000,
    "BypassTokensPerPeriod": 1000,
    "BypassReplenishmentPeriodSeconds": 5
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:3000"
    ]
  },
  "Embedding": {
    "Endpoint": "https://your-embedding-openai-resource.openai.azure.com/",
    "Deployment": "text-embedding-ada-002"
  },
  "RAGSearch": {
    "Endpoint": "https://your-search-service.search.windows.net",
    "IndexName": "knowledge",
    "TopK": 5,
    "VectorFieldName": "contentVector"
  },
  "AgentOrchestration": {
    "DefaultProvider": "AzureOpenAI",
    "RouterAgentName": "RouterAgent",
    "DefaultAgentName": "GeneralAdvisor",
    "Providers": {
      "AzureOpenAI": {
        "Endpoint": "https://your-foundry-resource.openai.azure.com/"
      }
    },
    "Agents": [
      {
        "Name": "RouterAgent",
        "Description": "Classifies user messages and routes them to the most appropriate specialist agent.",
        "SystemPrompt": "",
        "Provider": "AzureOpenAI",
        "DeploymentOrModel": "gpt-4o-mini",
        "Plugins": [],
        "Temperature": 0,
        "MaxTokens": 50
      },
      {
        "Name": "GeneralAdvisor",
        "Description": "General-purpose advisor for questions that do not clearly match any specialist domain.",
        "SystemPrompt": "You are a helpful general assistant. Answer questions as accurately as possible.",
        "Provider": "AzureOpenAI",
        "DeploymentOrModel": "gpt-4o",
        "Plugins": [],
        "Temperature": 0.7,
        "MaxTokens": 2000
      },
      {
        "Name": "ProductCatalog",
        "Description": "Helps users find products from the catalog.",
        "SystemPrompt": "You are a helpful product advisor. Answer questions about products clearly and concisely.",
        "Provider": "AzureOpenAI",
        "DeploymentOrModel": "gpt-4o",
        "Plugins": [ "ProductCatalog" ],
        "Temperature": 0.7,
        "MaxTokens": 2000
      },
      {
        "Name": "SupplierAdvisor",
        "Description": "Helps users find and evaluate suppliers of pharmaceutical raw materials.",
        "SystemPrompt": "You are a specialist in pharmaceutical raw material sourcing. Use the knowledge base to answer questions about suppliers, their products, certifications, origin, and quality standards. Be precise and objective.",
        "Provider": "AzureOpenAI",
        "DeploymentOrModel": "gpt-4o",
        "Plugins": [ "RAG" ],
        "Temperature": 0.2,
        "MaxTokens": 2000,
        "Review": {
          "Required": true,
          "AgentReviewerName": "ReviewerAgent",
          "ConfidenceScore": 0.85,
          "AttemptsToImprove": 2
        }
      },
      {
        "Name": "ReviewerAgent",
        "Description": "Validates and scores answers produced by specialist agents.",
        "SystemPrompt": "You are an answer quality reviewer. Given a user question and an AI-generated answer, evaluate the answer quality and return a confidence score between 0.0 and 1.0. When a minimum confidence threshold is provided, set isValid to false if your score is below that threshold. For instructionToImprove: if isValid is false, write a concise actionable instruction telling the agent what is missing or wrong. If isValid is true, return an empty string.\nReturn ONLY valid JSON in this exact format, nothing else: {\"isValid\": true, \"confidence\": 0.85, \"notes\": \"Brief explanation\", \"instructionToImprove\": \"Specific improvement instruction or empty string\"}",
        "Provider": "AzureOpenAI",
        "DeploymentOrModel": "gpt-4o-mini",
        "Plugins": [],
        "Temperature": 0,
        "MaxTokens": 200
      }
    ]
  }
}
